# Klaro environment variables (Vercel-compatible)
#
# To use real AI instead of the MockProvider:
#   1. Set NEXT_PUBLIC_AI_PROVIDER=anthropic
#   2. Set ANTHROPIC_API_KEY=sk-ant-... (get one at https://console.anthropic.com)
#   3. Restart `npm run dev`
#
# When NEXT_PUBLIC_AI_PROVIDER is unset (or set to anything other than
# "anthropic"), Klaro uses the MockProvider for offline development.
# No API key required for mock mode.

NEXT_PUBLIC_AI_PROVIDER=mock
ANTHROPIC_API_KEY=
